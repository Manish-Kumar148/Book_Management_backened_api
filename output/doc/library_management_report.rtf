6. app.js\par
const cors = require('cors');\par
const express = require('express');\par
const morgan = require('morgan');\par
\par
const bookRoutes = require('./routes/bookRoutes');\par
const \{ notFoundHandler, errorHandler \} = require('./middleware/errorMiddleware');\par
\par
const app = express();\par
\par
app.use(cors());\par
app.use(express.json());\par
app.use(morgan('dev'));\par
\par
app.get('/', (req, res) => \{\par
  res.status(200).json(\{\par
    success: true,\par
    message: 'Library Management Backend API is running.'\par
  \});\par
\});\par
\par
app.get('/health', (req, res) => \{\par
  res.status(200).json(\{\par
    success: true,\par
    status: 'UP'\par
  \});\par
\});\par
\par
app.use('/books', bookRoutes);\par
\par
app.use(notFoundHandler);\par
app.use(errorHandler);\par
\par
module.exports = app;\par
