8. Book Model\par
const mongoose = require('mongoose');\par
\par
const bookSchema = new mongoose.Schema(\par
  \{\par
    title: \{\par
      type: String,\par
      required: [true, 'Title is required'],\par
      trim: true\par
    \},\par
    author: \{\par
      type: String,\par
      required: [true, 'Author is required'],\par
      trim: true\par
    \},\par
    isbn: \{\par
      type: String,\par
      required: [true, 'ISBN is required'],\par
      unique: true,\par
      trim: true\par
    \},\par
    genre: \{\par
      type: String,\par
      required: [true, 'Genre is required'],\par
      trim: true\par
    \},\par
    publisher: \{\par
      type: String,\par
      required: [true, 'Publisher is required'],\par
      trim: true\par
    \},\par
    publicationYear: \{\par
      type: Number,\par
      min: [0, 'Publication year cannot be negative']\par
    \},\par
    totalCopies: \{\par
      type: Number,\par
      required: [true, 'Total copies is required'],\par
      min: [1, 'Total copies must be a positive number']\par
    \},\par
    availableCopies: \{\par
      type: Number,\par
      required: [true, 'Available copies is required'],\par
      min: [0, 'Available copies cannot be negative'],\par
      validate: \{\par
        validator(value) \{\par
          return value <= this.totalCopies;\par
        \},\par
        message: 'Available copies cannot exceed total copies'\par
      \}\par
    \},\par
    shelfLocation: \{\par
      type: String,\par
      trim: true\par
    \},\par
    bookType: \{\par
      type: String,\par
      enum: ['Reference', 'Circulating'],\par
      default: 'Circulating'\par
    \},\par
    status: \{\par
      type: String,\par
      enum: ['Available', 'Checked Out'],\par
      default: 'Available'\par
    \}\par
  \},\par
  \{\par
    timestamps: true\par
  \}\par
);\par
\par
module.exports = mongoose.model('Book', bookSchema);\par
\par
\par
9. Controller Logic\par
const Book = require('../models/Book');\par
\par
const createBook = async (req, res, next) => \{\par
  try \{\par
    const book = await Book.create(req.body);\par
    res.status(201).json(\{\par
      success: true,\par
      data: book\par
    \});\par
  \} catch (error) \{\par
    next(error);\par
  \}\par
\};\par
\par
const getBooks = async (req, res, next) => \{\par
  try \{\par
    const books = await Book.find().sort(\{ createdAt: -1 \});\par
    res.status(200).json(\{\par
      success: true,\par
      count: books.length,\par
      data: books\par
    \});\par
  \} catch (error) \{\par
    next(error);\par
  \}\par
\};\par
\par
const getBookById = async (req, res, next) => \{\par
  try \{\par
    const book = await Book.findById(req.params.id);\par
\par
    if (!book) \{\par
      return res.status(404).json(\{\par
        success: false,\par
        message: 'Book not found'\par
      \});\par
    \}\par
\par
    res.status(200).json(\{\par
      success: true,\par
      data: book\par
    \});\par
  \} catch (error) \{\par
    next(error);\par
  \}\par
\};\par
\par
const updateBook = async (req, res, next) => \{\par
  try \{\par
    const book = await Book.findByIdAndUpdate(req.params.id, req.body, \{\par
      new: true,\par
      runValidators: true\par
    \});\par
\par
    if (!book) \{\par
      return res.status(404).json(\{\par
        success: false,\par
        message: 'Book not found'\par
      \});\par
    \}\par
\par
    res.status(200).json(\{\par
      success: true,\par
      data: book\par
    \});\par
  \} catch (error) \{\par
    next(error);\par
  \}\par
\};\par
\par
const deleteBook = async (req, res, next) => \{\par
  try \{\par
    const book = await Book.findByIdAndDelete(req.params.id);\par
\par
    if (!book) \{\par
      return res.status(404).json(\{\par
        success: false,\par
        message: 'Book not found'\par
      \});\par
    \}\par
\par
    res.status(200).json(\{\par
      success: true,\par
      message: 'Book deleted successfully'\par
    \});\par
  \} catch (error) \{\par
    next(error);\par
  \}\par
\};\par
\par
const searchBooks = async (req, res, next) => \{\par
  try \{\par
    const \{ title, author \} = req.query;\par
\par
    if (!title && !author) \{\par
      return res.status(400).json(\{\par
        success: false,\par
        message: 'Provide title or author as a query parameter'\par
      \});\par
    \}\par
\par
    const query = \{\};\par
\par
    if (title) \{\par
      query.title = \{ $regex: title, $options: 'i' \};\par
    \}\par
\par
    if (author) \{\par
      query.author = \{ $regex: author, $options: 'i' \};\par
    \}\par
\par
    const books = await Book.find(query).sort(\{ title: 1 \});\par
\par
    res.status(200).json(\{\par
      success: true,\par
      count: books.length,\par
      data: books\par
    \});\par
  \} catch (error) \{\par
    next(error);\par
  \}\par
\};\par
\par
module.exports = \{\par
  createBook,\par
  getBooks,\par
  getBookById,\par
  updateBook,\par
  deleteBook,\par
  searchBooks\par
\};\par
\par
\par
10. Routes\par
const express = require('express');\par
\par
const \{\par
  createBook,\par
  getBooks,\par
  getBookById,\par
  updateBook,\par
  deleteBook,\par
  searchBooks\par
\} = require('../controllers/bookController');\par
\par
const router = express.Router();\par
\par
router.get('/search', searchBooks);\par
router.route('/').post(createBook).get(getBooks);\par
router.route('/:id').get(getBookById).put(updateBook).delete(deleteBook);\par
\par
module.exports = router;\par
